{
  "manifest_version": 3,
  "name": "Focus Flow",
  "version": "1.0",
  "description": "Pomodoro timer + todo list to keep you in the zone.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage", "alarms", "notifications"],
  "background": {
    "service_worker": "background.js"
  }
}
